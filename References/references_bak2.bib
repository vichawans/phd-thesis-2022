@article{rigbyRecentFutureTrends2014,
  title = {Recent and Future Trends in Synthetic Greenhouse Gas Radiative Forcing},
  author = {Rigby, M. and Prinn, R. G. and O'Doherty, S. and Miller, B. R. and Ivy, D. and M{\"u}hle, J. and Harth, C. M. and Salameh, P. K. and Arnold, T. and Weiss, R. F. and Krummel, P. B. and Steele, L. P. and Fraser, P. J. and Young, D. and Simmonds, P. G.},
