  title = {Photochemical Smog Pollution in the {{Bangkok Metropolitan Region}} of {{Thailand}} in Relation to {{O3}} Precursor Concentrations and Meteorological Conditions},
  author = {Zhang, B.-N. and Kim Oanh, N.T.},
