@article{sukmasPreferredOrientedCation2020,
  title = {Preferred Oriented Cation Configurations in High Pressure Phases {{IV}} and {{V}} of Methylammonium Lead Iodide Perovskite},
  author = {Sukmas, Wiwittawin and Sakulsupich, Vichawan and {Tsuppayakorn-aek}, Prutthipong and Pinsook, Udomsilp and Pakornchote, Teerachote and Klinkla, Rakchat and Bovornratanaraks, Thiti},
  year = 2020,
