  author = {Charlson, R.J. and Langner, J. and Rodhe, H. and Leovy, C.B. and Warren, S.G.},
  year = 1991,
  month = jan,
  journal = {Tellus A: Dynamic Meteorology and Oceanography},
  volume = {43},
  number = {4},
  pages = {152--163},
