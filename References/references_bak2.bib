  shorttitle = {Design and Implementation of the Infrastructure of {{HadGEM3}}},
  author = {Hewitt, H. T. and Copsey, D. and Culverwell, I. D. and Harris, C. M. and Hill, R. S. R. and Keen, A. B. and McLaren, A. J. and Hunke, E. C.},
