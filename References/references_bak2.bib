  doi = {10.1029/95JD02897},
  urldate = {2023-10-30},
  abstract = {Recent estimates of global or hemispheric average forcing of climate by anthropogenic sulfate aerosol caused by scattering of shortwave radiation (``direct'' effect) are uncertain by somewhat more than a factor of 2. The principal sources of this uncertainty are atmospheric chemistry properties (yield, residence time), and microphysical properties (scattering efficiency, upscatter fraction, and the dependence of these properties on particle size, composition, and relative humidity, (RH)). This paper examines the sensitivity of forcing to these microphysical properties to identify and improve understanding of the properties required to reduce the uncertainty in the forcing. The relations between aerosol loading and forcing developed here are suitable for comparing modeled and measured aerosol forcing at specific locations and for use in climate models, provided aerosol composition and microphysical properties are known, calculated, or assumed. Results are presented showing the dependence of scattering efficiency, upscatter fraction, and normalized forcing (W m-2/g(SO24-) m-2 or W g(SO24-)-1) on dry particle size (expressed as mole(sulfate) per particle), composition ((NH4)2SO4, NH4HSO4, H2SO4), solar zenith angle, latitude, and season. Forcing is strongly dependent on dry particle size and RH but is relatively insensitive to composition. The normalized forcing can be integrated over a known or assumed size distribution to evaluate the sulfate aerosol forcing. Global and annual average values of the normalized forcing are evaluated as a function of particle size and RH. Depending on values of these variables, normalized forcing may be less than, intermediate to, or greater than the range of previous estimates of sulfate aerosol forcing.},
  langid = {english},
  keywords = {broken,VS_paper1},
  file = {C\:\\Users\\print\\Zotero\\storage\\NBR76KML\\Nemesure et al. - 1995 - Direct shortwave forcing of climate by the anthrop.pdf;C\:\\Users\\print\\Zotero\\storage\\5YM9WFSB\\95JD02897.html}
}

@article{neubauerGlobalAerosolClimate2019,
  title = {The Global Aerosol--Climate Model {{ECHAM6}}.3--{{HAM2}}.3 -- {{Part}} 2: {{Cloud}} Evaluation, Aerosol Radiative Forcing, and Climate Sensitivity},
  shorttitle = {The Global Aerosol--Climate Model {{ECHAM6}}.3--{{HAM2}}.3 -- {{Part}} 2},
  author = {Neubauer, David and Ferrachat, Sylvaine and {Siegenthaler-Le Drian}, Colombe and Stier, Philip and Partridge, Daniel G. and Tegen, Ina and Bey, Isabelle and Stanelle, Tanja and Kokkola, Harri and Lohmann, Ulrike},
  year = 2019,
  month = aug,
  journal = {Geoscientific Model Development},
  volume = {12},
  number = {8},
  pages = {3609--3639},
  publisher = {Copernicus GmbH},
  issn = {1991-959X},
  doi = {10.5194/gmd-12-3609-2019},
  urldate = {2022-05-03},
  abstract = {{$<$}p{$><$}strong class="journal-contentHeaderColor"{$>$}Abstract.{$<$}/strong{$>$} The global aerosol--climate model ECHAM6.3--HAM2.3 (E63H23) as well as the previous model versions ECHAM5.5--HAM2.0 (E55H20) and ECHAM6.1--HAM2.2 (E61H22) are evaluated using global observational datasets for clouds and precipitation. In E63H23, the amount of low clouds, the liquid and ice water path, and cloud radiative effects are more realistic than in previous model versions. E63H23 has a more physically based aerosol activation scheme, improvements in the cloud cover scheme, changes in the detrainment of convective clouds, changes in the sticking efficiency for the accretion of ice crystals by snow, consistent ice crystal shapes throughout the model, and changes in mixed-phase freezing; an inconsistency in ice crystal number concentration (ICNC) in cirrus clouds was also removed. Common biases in ECHAM and in E63H23 (and in previous ECHAM--HAM versions) are a cloud amount in stratocumulus regions that is too low and deep convective clouds over the Atlantic and Pacific oceans that form too close to the continents (while tropical land precipitation is underestimated). There are indications that ICNCs are overestimated in E63H23.{$<$}/p{$>$} {$<$}p{$>$}Since clouds are important for effective radiative forcing due to aerosol--radiation and aerosol--cloud interactions (ERF\textsubscript{ari+aci}) and equilibrium climate sensitivity (ECS), differences in ERF\textsubscript{ari+aci} and ECS between the model versions were also analyzed. ERF\textsubscript{ari+aci} is weaker in E63H23 (-1.0\&thinsp;W\&thinsp;m\textsuperscript{-2}) than in E61H22 (-1.2\&thinsp;W\&thinsp;m\textsuperscript{-2}) (or E55H20; -1.1\&thinsp;W\&thinsp;m\textsuperscript{-2}). This is caused by the weaker shortwave ERF\textsubscript{ari+aci} (a new aerosol activation scheme and sea salt emission parameterization in E63H23, more realistic simulation of cloud water) overcompensating for the weaker longwave ERF\textsubscript{ari+aci} (removal of an inconsistency in ICNC in cirrus clouds in E61H22).{$<$}/p{$>$} {$<$}p{$>$}The decrease in ECS in E63H23 (2.5\&thinsp;K) compared to E61H22 (2.8\&thinsp;K) is due to changes in the entrainment rate for shallow convection (affecting the cloud amount feedback) and a stronger cloud phase feedback.{$<$}/p{$>$} {$<$}p{$>$}Experiments with minimum cloud droplet number concentrations (CDNCmin) of 40\&thinsp;cm\textsuperscript{-3} or 10\&thinsp;cm\textsuperscript{-3} show that a higher value of CDNCmin reduces ERF\textsubscript{ari+aci} as well as ECS in E63H23.{$<$}/p{$>$}},
  langid = {english},
  keywords = {model description},
  file = {C\:\\Users\\print\\Zotero\\storage\\FW4RRDV6\\Neubauer et al. - 2019 - The global aerosol–climate model ECHAM6.3–HAM2.3 –.pdf;C\:\\Users\\print\\Zotero\\storage\\KMC8S62I\\2019.html}
}

