@article{oconnorApportionmentPreIndustrial2022,
  title = {Apportionment of the {{Pre}}-{{Industrial}} to {{Present}}-{{Day Climate Forcing}} by {{Methane Using UKESM1}}: {{The Role}} of the {{Cloud Radiative Effect}}},
  shorttitle = {Apportionment of the {{Pre}}-{{Industrial}} to {{Present}}-{{Day Climate Forcing}} by {{Methane Using UKESM1}}},
  author = {O'Connor, Fiona M. and Johnson, Ben T. and Jamil, Omar and Andrews, Timothy and Mulcahy, Jane P. and Manners, James},
  year = 2022,
  month = oct,
  journal = {Journal of Advances in Modeling Earth Systems},
  volume = {14},
  number = {10},
  issn = {1942-2466, 1942-2466},
  doi = {10.1029/2022MS002991},
  urldate = {2023-01-26},
  abstract = {The Year 1850 to 2014 increase in methane from 808 to 1831 ppb leads to an effective radiative forcing (ERF) of 0.97 \textpm{} 0.04 W m{$\mkern1mu-$}2 in the United Kingdom's Earth System Model, UKESM1. The direct methane contribution is 0.54 \textpm{} 0.04 W m{$\mkern1mu-$}2. It is better represented in UKESM1 than in its predecessor model HadGEM2 due to shortwave and longwave absorption improvements and the absence of an anomalous dust response in the UKESM1 simulations. An indirect ozone ERF of 0.13--0.20 W m{$\mkern1mu-$}2 is due to the tropospheric ozone increase outweighing that of the stratospheric decrease. The indirect water vapor ERF of 0.02--0.07 W m{$\mkern1mu-$}2 is consistent with previous estimates. The methane increase also leads to a cloud radiative effect of 0.12 \textpm{} 0.02 W m{$\mkern1mu-$}2 from thermodynamic adjustments and aerosol-cloud interactions (aci). Shortwave and longwave contributions of 0.23 and -0.35 W m{$\mkern1mu-$}2 to the cloud forcing arise from radiative heating and stabilization of the upper troposphere, reducing convection and global cloud cover. The aerosol-mediated contribution (0.28--0.30 W m{$\mkern1mu-$}2) is due to changes in oxidants reducing new particle formation (-8\%), shifting the aerosol size distribution toward fewer but larger particles. Cloud droplet number concentration decreases and cloud droplet effective radius increases. This reduction in the Twomey effect switches the cloud forcing sign (-0.14 to 0.12 W m{$\mkern1mu-$}2) and is due to chemistry-aerosol-cloud coupling in UKESM1. Despite uncertainties in rapid adjustments and process representation in models, these results highlight the potential importance of chemistry-aerosol-cloud interactions and dynamical adjustments in climate forcing.},
  langid = {english},
  keywords = {VS_paper1},
  file = {C:\Users\print\Zotero\storage\CSYAIGQZ\O’Connor et al. - 2022 - Apportionment of the Pre‐Industrial to Present‐Day.pdf}
}

@article{oconnorAssessmentPreindustrialPresentday2021,
  title = {Assessment of Pre-Industrial to Present-Day Anthropogenic Climate Forcing in {{UKESM1}}},
  author = {O'Connor, Fiona M. and Abraham, N. Luke and Dalvi, Mohit and Folberth, Gerd A. and Griffiths, Paul T. and Hardacre, Catherine and Johnson, Ben T. and Kahana, Ron and Keeble, James and Kim, Byeonghyeon and Morgenstern, Olaf and Mulcahy, Jane P. and Richardson, Mark and Robertson, Eddy and Seo, Jeongbyn and Shim, Sungbo and Teixeira, Jo{\~a}o C. and Turnock, Steven T. and Williams, Jonny and Wiltshire, Andrew J. and Woodward, Stephanie and Zeng, Guang},
  year = 2021,
  month = jan,
  journal = {Atmospheric Chemistry and Physics},
  volume = {21},
  number = {2},
  pages = {1211--1243},
  publisher = {Copernicus GmbH},
  issn = {1680-7316},
  doi = {10.5194/acp-21-1211-2021},
  urldate = {2022-02-18},
  abstract = {{$<$}p{$><$}strong class="journal-contentHeaderColor"{$>$}Abstract.{$<$}/strong{$>$} Quantifying forcings from anthropogenic perturbations to the Earth system (ES) is important for understanding changes in climate since the pre-industrial (PI) period. Here, we quantify and analyse a wide range of present-day (PD) anthropogenic effective radiative forcings (ERFs) with the UK's Earth System Model (ESM), UKESM1, following the protocols defined by the Radiative Forcing Model Intercomparison Project (RFMIP) and the Aerosol and Chemistry Model Intercomparison Project (AerChemMIP). In particular, quantifying ERFs that include rapid adjustments within a full ESM enables the role of various chemistry--aerosol--cloud interactions to be investigated.{$<$}/p{$>$} {$<$}p{$>$}Global mean ERFs for the PD (year 2014) relative to the PI (year 1850) period for carbon dioxide (CO\textsubscript{2}), nitrous oxide (N\textsubscript{2}O), ozone-depleting substances (ODSs), and methane (CH\textsubscript{4}) are 1.89 \textpm{} 0.04, 0.25 \textpm{} 0.04, -0.18 \textpm{} 0.04, and 0.97 \textpm{} 0.04 W m\textsuperscript{-2}, respectively. The total greenhouse gas (GHG) ERF is 2.92 \textpm{} 0.04 W m\textsuperscript{-2}.{$<$}/p{$>$} {$<$}p{$>$}UKESM1 has an aerosol ERF of -1.09 \textpm{} 0.04 W m\textsuperscript{-2}. A relatively strong negative forcing from aerosol--cloud interactions (ACI) and a small negative instantaneous forcing from aerosol--radiation interactions (ARI) from sulfate and organic carbon (OC) are partially offset by a substantial forcing from black carbon (BC) absorption. Internal mixing and chemical interactions imply that neither the forcing from ARI nor ACI is linear, making the aerosol ERF less than the sum of the individual speciated aerosol ERFs.{$<$}/p{$>$} {$<$}p{$>$}Ozone (O\textsubscript{3}) precursor gases consisting of volatile organic compounds (VOCs), carbon monoxide (CO), and nitrogen oxides (NO\textsubscript{\emph{x}}), but excluding CH\textsubscript{4}, exert a positive radiative forcing due to increases in O\textsubscript{3}. However, they also lead to oxidant changes, which in turn cause an indirect aerosol ERF. The net effect is that the ERF from PD--PI changes in NO\textsubscript{\emph{x}} emissions is negligible at 0.03 \textpm{} 0.04 W m\textsuperscript{-2}, while the ERF from changes in VOC and CO emissions is 0.33 \textpm{} 0.04 W m\textsuperscript{-2}. Together, aerosol and O\textsubscript{3} precursors (called near-term climate forcers (NTCFs) in the context of AerChemMIP) exert an ERF of -1.03 \textpm{} 0.04 W m\textsuperscript{-2}, mainly due to changes in the cloud radiative effect (CRE). There is also a negative ERF from land use change (-0.17 \textpm{} 0.04 W m\textsuperscript{-2}). When adjusted from year 1850 to 1700, it is more negative than the range of previous estimates, and is most likely due to too strong an albedo response. In combination, the net anthropogenic ERF (1.76 \textpm{} 0.04 W m\textsuperscript{-2}) is consistent with other estimates.{$<$}/p{$>$} {$<$}p{$>$}By including interactions between GHGs, stratospheric and tropospheric O\textsubscript{3}, aerosols, and clouds, this work demonstrates the importance of ES interactions when quantifying ERFs. It also suggests that rapid adjustments need to include chemical as well as physical adjustments to fully account for complex ES interactions.{$<$}/p{$>$}},
  langid = {english},
  keywords = {duplicate,VS_paper1},
  file = {C\:\\Users\\print\\Zotero\\storage\\77TZVLJ4\\acp-21-1211-2021.pdf;C\:\\Users\\print\\Zotero\\storage\\LMG6TNE4\\O'Connor et al. - 2021 - Assessment of pre-industrial to present-day anthro.pdf;C\:\\Users\\print\\Zotero\\storage\\WUBHH92T\\O'Connor et al. - 2021 - Assessment of pre-industrial to present-day anthro.pdf;C\:\\Users\\print\\Zotero\\storage\\NFQA7V3P\\2021.html}
}

@article{oconnorEvaluationNewUKCA2014,
  title = {Evaluation of the New {{UKCA}} Climate-Composition Model -- {{Part}} 2: {{The Troposphere}}},
  shorttitle = {Evaluation of the New {{UKCA}} Climate-Composition Model -- {{Part}} 2},
  author = {O'Connor, F. M. and Johnson, C. E. and Morgenstern, O. and Abraham, N. L. and Braesicke, P. and Dalvi, M. and Folberth, G. A. and Sanderson, M. G. and Telford, P. J. and Voulgarakis, A. and Young, P. J. and Zeng, G. and Collins, W. J. and Pyle, J. A.},
  year = 2014,
  month = jan,
  journal = {Geoscientific Model Development},
  volume = {7},
  number = {1},
  pages = {41--91},
  publisher = {Copernicus GmbH},
  issn = {1991-959X},
  doi = {10.5194/gmd-7-41-2014},
  urldate = {2023-11-07},
  abstract = {In this paper, we present a description of the tropospheric chemistry component of the UK Chemistry and Aerosols (UKCA) model which has been coupled to the Met Office Hadley Centre's HadGEM family of climate models. We assess the model's transport and scavenging processes, in particular focussing on convective transport, boundary layer mixing, wet scavenging and inter-hemispheric exchange. Simulations with UKCA of the short-lived radon tracer suggest that modelled distributions are comparable to those of other models and the comparison with observations indicate that apart from a few locations, boundary layer mixing and convective transport are effective in the model as a means of vertically redistributing surface emissions of radon. Comparisons of modelled lead tracer concentrations with observations suggest that UKCA captures surface concentrations in both hemispheres very well, although there is a tendency to underestimate the observed geographical and interannual variability in the Northern Hemisphere. In particular, UKCA replicates the shape and absolute concentrations of observed lead profiles, a key test in the evaluation of a model's wet scavenging scheme. The timescale for inter-hemispheric transport, calculated in the model using a simple krypton tracer experiment, does appear to be long relative to other models and could indicate deficiencies in tropical deep convection and/or insufficient boundary layer mixing. We also describe the main components of the tropospheric chemistry and evaluate it against observations and other tropospheric chemistry models. In particular, from a climate forcing perspective, present-day observed surface methane concentrations and tropospheric ozone concentrations are reproduced very well by the model, thereby making it suitable for long centennial integrations as well as studies of biogeochemical feedbacks. Results from both historical and future simulations with UKCA tropospheric chemistry are presented. Future projections of tropospheric ozone vary with the Representative Concentration Pathway (RCP). In RCP2.6, for example, tropospheric ozone increases up to 2010 and then declines by 13\% of its year-2000 global mean by the end of the century. In RCP8.5, tropospheric ozone continues to rise steadily throughout the 21st century, with methane being the main driving factor. Finally, we highlight aspects of the UKCA model which are undergoing and/or have undergone recent developments and are suitable for inclusion in a next-generation Earth System Model.},
  langid = {english},
  keywords = {broken,VS_paper1},
  file = {C\:\\Users\\print\\Zotero\\storage\\5T2R887B\\O'Connor et al. - 2014 - Evaluation of the new UKCA climate-composition model – Part 2 The Troposphere.pdf;C\:\\Users\\print\\Zotero\\storage\\J555ZDM3\\O'Connor et al. - 2014 - Evaluation of the new UKCA climate-composition mod.pdf}
}

