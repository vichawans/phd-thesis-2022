@article{grandeyBackgroundConditionsInfluence2019,
  title = {Background {{Conditions Influence}} the {{Estimated Cloud Radiative Effects}} of {{Anthropogenic Aerosol Emissions From Different Source Regions}}},
  author = {Grandey, Benjamin S. and Wang, Chien},
  year = 2019,
  journal = {Journal of Geophysical Research: Atmospheres},
  volume = {124},
  number = {4},
  pages = {2276--2295},
  issn = {2169-8996},
  doi = {10.1029/2018JD029644},
  urldate = {2025-09-21},
  abstract = {Using the Community Earth System Model, with the Community Atmosphere Model version 5.3, we investigate the cloud radiative effects of anthropogenic aerosols emitted from different source regions and global shipping. We also analyze aerosol burdens, cloud condensation nuclei concentration, liquid water path, and ice water path. Due to transboundary transport and sublinearity in the response of clouds to aerosols, the cloud radiative effects of emissions from a given source region are influenced by emissions from other source regions. For example, the shortwave cloud radiative effect of shipping is -0.39 \textpm{} 0.03 W/m2 when other anthropogenic emissions sources are present (the ``present-day background'' assumption) compared with -0.60 \textpm{} 0.03 W/m2 when other anthropogenic emissions sources are absent (the ``natural background'' assumption). In general, the cloud radiative effects are weaker if present-day background conditions are assumed compared with if natural background conditions are assumed. Assumptions about background conditions should be carefully considered when investigating the climate impacts of aerosol emissions from a given source region.},
  copyright = {\copyright 2019. The Authors.},
  langid = {english},
  keywords = {aerosols,anthropogenic aerosol emissions,background conditions,climate model,radiative forcing,VS_paper2},
  file = {C\:\\Users\\print\\Zotero\\storage\\VTNHZRGW\\Grandey and Wang - 2019 - Background Conditions Influence the Estimated Cloud Radiative Effects of Anthropogenic Aerosol Emiss.pdf;C\:\\Users\\print\\Zotero\\storage\\TQHQ6SNV\\2018JD029644.html}
}

@article{gregoireMechanismsHotCorrosion2018,
  title = {Mechanisms of Hot Corrosion of Pure Nickel at 700{$^\circ$}{{C}}: {{Influence}} of Testing Conditions},
  shorttitle = {Mechanisms of Hot Corrosion of Pure Nickel at 700{$^\circ$}{{C}}},
  author = {Gr{\'e}goire, Benjamin and Montero, Xabier and Galetz, Mathias C. and Bonnet, Gilles and Pedraza, Fernando},
  year = 2018,
  month = aug,
  journal = {Corrosion Science},
  volume = {141},
  pages = {211--220},
  issn = {0010938X},
  doi = {10.1016/j.corsci.2018.06.009},
  urldate = {2020-03-06},
  abstract = {The hot corrosion behaviour of pure nickel was investigated at 700 {$^\circ$}C to highlight the influence of testing conditions (composition of the atmosphere and presence or not of a Na2SO4 deposit) on the mechanisms of hot corrosion. The influence of SO2/SO3 inward transport through the porous NiO growing scales was studied by exposing nickel in synthetic air and in synthetic air + 0.5\% SO2/SO3 without Na2SO4. The addition of Na2SO4 decreased the pO2 and the pSO3 at the sample surface, which promoted the formation of Ni-S liquid solution at the metal/scale interface. A sufficient pSO3 was required to stabilize liquid Na2SO4-NiSO4 solutions and simulate Type-II hot corrosion conditions.},
  langid = {english},
  keywords = {nosource}
}

@article{gregoryHowAccuratelyCan2020,
  title = {How Accurately Can the Climate Sensitivity to \$\$\textbackslash hbox \textbraceleft{{CO}}\textbraceright\_\textbraceleft 2\textbraceright\$\$ Be Estimated from Historical Climate Change?},
  author = {Gregory, J. M. and Andrews, T. and Ceppi, P. and Mauritsen, T. and Webb, M. J.},
  year = 2020,
  month = jan,
  journal = {Climate Dynamics},
  volume = {54},
  number = {1},
  pages = {129--157},
  issn = {1432-0894},
  doi = {10.1007/s00382-019-04991-y},
  urldate = {2025-06-20},
  abstract = {The equilibrium climate sensitivity (ECS, in K) to \$\$\textbackslash hbox \textbraceleft CO\textbraceright\_\textbraceleft 2\textbraceright\$\$ doubling is a large source of uncertainty in projections of future anthropogenic climate change. Estimates of ECS made from non-equilibrium states or in response to radiative forcings other than \$\$\textbackslash hbox \textbraceleft 2\textbraceright\textbackslash times \textbackslash hbox \textbraceleft CO\textbraceright\_\textbraceleft 2\textbraceright\$\$ are called ``effective climate sensitivity'' (EffCS, in K). Taking a ``perfect-model'' approach, using coupled atmosphere--ocean general circulation model (AOGCM) experiments, we evaluate the accuracy with which \$\$\textbackslash hbox \textbraceleft CO\textbraceright\_\textbraceleft 2\textbraceright\$\$ EffCS can be estimated from climate change in the ``historical'' period (since about 1860). We find that (1) for statistical reasons, unforced variability makes the estimate of historical EffCS both uncertain and biased; it is overestimated by about 10\% if the energy balance is applied to the entire historical period, 20\% for 30-year periods, and larger factors for interannual variability, (2) systematic uncertainty in historical radiative forcing translates into an uncertainty of \$\$\textbraceleft\textbackslash pm \textbraceright\textbackslash,30\textbackslash, \textbraceleft\textbackslash rm to\textbraceright{} \textbackslash,45\textbackslash\%\$\$ (standard deviation) in historical EffCS, (3) the response to the changing relative importance of the forcing agents, principally \$\$\textbackslash hbox \textbraceleft CO\textbraceright\_\textbraceleft 2\textbraceright\$\$ and volcanic aerosol, causes historical EffCS to vary over multidecadal timescales by a factor of two. In recent decades it reached its maximum in the AOGCM historical experiment (similar to the multimodel-mean \$\$\textbackslash hbox \textbraceleft CO\textbraceright\_\textbraceleft 2\textbraceright\$\$ EffCS of 3.6 K from idealised experiments), but its minimum in the real world (1.6 K for an observational estimate for 1985--2011, similar to the multimodel-mean value for volcanic forcing). The real-world variations mean that historical EffCS underestimates \$\$\textbackslash hbox \textbraceleft CO\textbraceright\_\textbraceleft 2\textbraceright\$\$ EffCS by 30\% when considering the entire historical period. The difference for recent decades implies that either unforced variability or the response to volcanic forcing causes a much stronger regional pattern of sea surface temperature change in the real world than in AOGCMs. We speculate that this could be explained by a deficiency in simulated coupled atmosphere--ocean feedbacks which reinforce the pattern (resembling the Interdecadal Pacific Oscillation in some respects) that causes the low EffCS. We conclude that energy-balance estimates of \$\$\textbackslash hbox \textbraceleft CO\textbraceright\_\textbraceleft 2\textbraceright\$\$ EffCS are most accurate from periods unaffected by volcanic forcing. Atmosphere GCMs provided with observed sea surface temperature for the 1920s to the 1950s, which was such a period, give a range of about 2.0--4.5 K, agreeing with idealised \$\$\textbackslash hbox \textbraceleft CO\textbraceright\_\textbraceleft 2\textbraceright\$\$ AOGCM experiments; the consistency is a reason for confidence in this range as an estimate of \$\$\textbackslash hbox \textbraceleft CO\textbraceright\_\textbraceleft 2\textbraceright\$\$ EffCS. Unless another explosive volcanic eruption occurs, the first 30 years of the present century may give a more accurate energy-balance historical estimate of this quantity.},
  langid = {english},
  keywords = {Carbon cycle,Climate and Earth System Modelling,Climate feedback,Climate Sciences,Climate sensitivity,Earth and Environmental Sciences,Earth System Sciences,Historical Geology,Volcanic forcing},
  file = {C:\Users\print\Zotero\storage\TQELF7HX\Gregory et al. - 2020 - How accurately can the climate sensitivity to $$hbox CO _ 2 $$ be estimated from historical climat.pdf}
}

@article{gregoryNewMethodDiagnosing2004,
  title = {A New Method for Diagnosing Radiative Forcing and Climate Sensitivity},
  author = {Gregory, J. M. and Ingram, W. J. and Palmer, M. A. and Jones, G. S. and Stott, P. A. and Thorpe, R. B. and Lowe, J. A. and Johns, T. C. and Williams, K. D.},
  year = 2004,
  journal = {Geophysical Research Letters},
  volume = {31},
  number = {3},
  issn = {1944-8007},
  doi = {10.1029/2003GL018747},
  urldate = {2023-03-08},
  abstract = {We describe a new method for evaluating the radiative forcing, the climate feedback parameter (W m-2 K-1) and hence the effective climate sensitivity from any GCM experiment in which the climate is responding to a constant forcing. The method is simply to regress the top of atmosphere radiative flux against the global average surface air temperature change. This method does not require special integrations or off-line estimates, such as for stratospheric adjustment, to obtain the forcing, and eliminates the need for double radiation calculations and tropopause radiative fluxes. We show that for CO2 and solar forcing in a slab model and an AOGCM the method gives results consistent with those obtained by conventional methods. For a single integration it is less precise but since it does not require a steady state to be reached its precision could be improved by running an ensemble of short integrations.},
  langid = {english},
  file = {C\:\\Users\\print\\Zotero\\storage\\F962TEA8\\Gregory et al_2004_A new method for diagnosing radiative forcing and climate sensitivity.pdf;C\:\\Users\\print\\Zotero\\storage\\AZ9WZ8SJ\\2003GL018747.html}
}

@article{griffithsChangingRoleStratosphere2020,
  title = {On the {{Changing Role}} of the {{Stratosphere}} on the {{Tropospheric Ozone Budget}}: 1979--2010},
  shorttitle = {On the {{Changing Role}} of the {{Stratosphere}} on the {{Tropospheric Ozone Budget}}},
  author = {Griffiths, P. T. and Keeble, J. and Shin, Y. M. and Abraham, N. L. and Archibald, A. T. and Pyle, J. A.},
  year = 2020,
  journal = {Geophysical Research Letters},
  volume = {47},
  number = {10},
  pages = {e2019GL086901},
  issn = {1944-8007},
  doi = {10.1029/2019GL086901},
  urldate = {2026-02-17},
  abstract = {We study the evolution of tropospheric ozone over the period 1979--2010 using a chemistry-climate model employing a stratosphere-troposphere chemistry scheme. By running with specified dynamics, the key feedback of composition on meteorology is suppressed, isolating the chemical response. By using historical forcings and emissions, interactions between processes are realistically represented. We use the model to assess how the ozone responds over time and to investigate model responses and trends. We find that the chlorofluorocarbon (CFC)-driven decrease in stratospheric ozone plays a significant role in the tropospheric ozone burden. Over the period 1979--1994, the decline in transport of ozone from the stratosphere, partially offsets an emissions-driven increase in tropospheric ozone production. From 1994--2010, despite a leveling off in emissions, increased stratosphere-to-troposphere transport of ozone drives a small increase in the tropospheric ozone burden. These results have implications for the impact of future stratospheric ozone recovery on air quality and radiative forcing.},
  copyright = {\copyright 2020. The Authors},
  langid = {english},
  keywords = {budget,ozone,stratosphere-troposphere,transport,tropospheric},
  file = {C\:\\Users\\print\\Zotero\\storage\\SJGHIJAS\\Griffiths et al. - 2020 - On the Changing Role of the Stratosphere on the Tropospheric Ozone Budget 1979–2010.pdf;C\:\\Users\\print\\Zotero\\storage\\4XDIK3AV\\2019GL086901.html}
}

@article{griffithsTroposphericOzoneCMIP62021,
  title = {Tropospheric Ozone in {{CMIP6}} Simulations},
