  shorttitle = {The {{NASA Atmospheric Tomography}} ({{ATom}}) {{Mission}}},
  author = {Thompson, Chelsea R. and Wofsy, Steven C. and Prather, Michael J. and Newman, Paul A. and Hanisco, Thomas F. and Ryerson, Thomas B. and Fahey, David W. and Apel, Eric C. and Brock, Charles A. and Brune, William H. and Froyd, Karl and Katich, Joseph M. and Nicely, Julie M. and Peischl, Jeff and Ray, Eric and Veres, Patrick R. and Wang, Siyuan and Allen, Hannah M. and Asher, Elizabeth and Bian, Huisheng and Blake, Donald and Bourgeois, Ilann and Budney, John and Bui, T. Paul and Butler, Amy and {Campuzano-Jost}, Pedro and Chang, Cecilia and Chin, Mian and Commane, R{\'o}is{\'i}n and Correa, Gus and Crounse, John D. and Daube, Bruce and Dibb, Jack E. and DiGangi, Joshua P. and Diskin, Glenn S. and Dollner, Maximilian and Elkins, James W. and Fiore, Arlene M. and Flynn, Clare M. and Guo, Hao and Hall, Samuel R. and Hannun, Reem A. and Hills, Alan and Hintsa, Eric J. and Hodzic, Alma and Hornbrook, Rebecca S. and Huey, L. Greg and Jimenez, Jose L. and Keeling, Ralph F. and Kim, Michelle J. and Kupc, Agnieszka and Lacey, Forrest and Lait, Leslie R. and Lamarque, Jean-Francois and Liu, Junhua and McKain, Kathryn and Meinardi, Simone and Miller, David O. and Montzka, Stephen A. and Moore, Fred L. and Morgan, Eric J. and Murphy, Daniel M. and Murray, Lee T. and Nault, Benjamin A. and Neuman, J. Andrew and Nguyen, Louis and Gonzalez, Yenny and Rollins, Andrew and Rosenlof, Karen and Sargent, Maryann and Schill, Gregory and Schwarz, Joshua P. and Clair, Jason M. St and Steenrod, Stephen D. and Stephens, Britton B. and Strahan, Susan E. and Strode, Sarah A. and Sweeney, Colm and Thames, Alexander B. and Ullmann, Kirk and Wagner, Nicholas and Weber, Rodney and Weinzierl, Bernadett and Wennberg, Paul O. and Williamson, Christina J. and Wolfe, Glenn M. and Zeng, Linghan},
  year = 2022,
  month = mar,
  journal = {Bulletin of the American Meteorological Society},
  volume = {103},
  number = {3},
  pages = {E761-E790},
  publisher = {American Meteorological Society},
  issn = {0003-0007, 1520-0477},
  doi = {10.1175/BAMS-D-20-0315.1},
  urldate = {2023-03-22},
  abstract = {Abstract This article provides an overview of the NASA Atmospheric Tomography (ATom) mission and a summary of selected scientific findings to date. ATom was an airborne measurements and modeling campaign aimed at characterizing the composition and chemistry of the troposphere over the most remote regions of the Pacific, Southern, Atlantic, and Arctic Oceans, and examining the impact of anthropogenic and natural emissions on a global scale. These remote regions dominate global chemical reactivity and are exceptionally important for global air quality and climate. ATom data provide the in situ measurements needed to understand the range of chemical species and their reactions, and to test satellite remote sensing observations and global models over large regions of the remote atmosphere. Lack of data in these regions, particularly over the oceans, has limited our understanding of how atmospheric composition is changing in response to shifting anthropogenic emissions and physical climate change. ATom was designed as a global-scale tomographic sampling mission with extensive geographic and seasonal coverage, tropospheric vertical profiling, and detailed speciation of reactive compounds and pollution tracers. ATom flew the NASA DC-8 research aircraft over four seasons to collect a comprehensive suite of measurements of gases, aerosols, and radical species from the remote troposphere and lower stratosphere on four global circuits from 2016 to 2018. Flights maintained near-continuous vertical profiling of 0.15--13-km altitudes on long meridional transects of the Pacific and Atlantic Ocean basins. Analysis and modeling of ATom data have led to the significant early findings highlighted here.},
  chapter = {Bulletin of the American Meteorological Society},
  langid = {english},
  keywords = {broken},
  file = {C:\Users\print\Zotero\storage\J4SR8ZZU\Thompson et al. - 2022 - The NASA Atmospheric Tomography (ATom) Mission Im.pdf}
}

