@article{vogelEarlyInflightDetection2011a,
  title = {Early In-Flight Detection of {{SO}}{\textsubscript{2}} via {{Differential Optical Absorption Spectroscopy}}: A Feasible Aviation Safety Measure to Prevent Potential Encounters with Volcanic Plumes},
  shorttitle = {Early In-Flight Detection of {{SO}}{\textsubscript{2}} via {{Differential Optical Absorption Spectroscopy}}},
  author = {Vogel, L. and Galle, B. and Kern, C. and Delgado Granados, H. and Conde, V. and Norman, P. and Arellano, S. and Landgren, O. and L{\"u}bcke, P. and Alvarez Nieves, J. M. and C{\'a}rdenas Gonz{\'a}les, L. and Platt, U.},
  year = 2011,
  month = sep,
  journal = {Atmospheric Measurement Techniques},
  volume = {4},
  number = {9},
  pages = {1785--1804},
  publisher = {Copernicus GmbH},
  issn = {1867-1381},
  doi = {10.5194/amt-4-1785-2011},
  urldate = {2020-12-14},
  abstract = {{$<$}p{$><$}strong{$>$}Abstract.{$<$}/strong{$>$} Volcanic ash constitutes a risk to aviation, mainly due to its ability to cause jet engines to fail. Other risks include the possibility of abrasion of windshields and potentially serious damage to avionic systems. These hazards have been widely recognized since the early 1980s, when volcanic ash provoked several incidents of engine failure in commercial aircraft. In addition to volcanic ash, volcanic gases also pose a threat. Prolonged and/or cumulative exposure to sulphur dioxide (SO\textsubscript{2}) or sulphuric acid (H\textsubscript{2}SO\textsubscript{4}) aerosols potentially affects e.g. windows, air frame and may cause permanent damage to engines. SO\textsubscript{2} receives most attention among the gas species commonly found in volcanic plumes because its presence above the lower troposphere is a clear proxy for a volcanic cloud and indicates that fine ash could also be present. {$<$}br{$><$}br{$>$} Up to now, remote sensing of SO\textsubscript{2} via Differential Optical Absorption Spectroscopy (DOAS) in the ultraviolet spectral region has been used to measure volcanic clouds from ground based, airborne and satellite platforms. Attention has been given to volcanic emission strength, chemistry inside volcanic clouds and measurement procedures were adapted accordingly. Here we present a set of experimental and model results, highlighting the feasibility of DOAS to be used as an airborne early detection system of SO\textsubscript{2} in two spatial dimensions. In order to prove our new concept, simultaneous airborne and ground-based measurements of the plume of Popocat\'epetl volcano, Mexico, were conducted in April 2010. The plume extended at an altitude around 5250 m above sea level and was approached and traversed at the same altitude with several forward looking DOAS systems aboard an airplane. These DOAS systems measured SO\textsubscript{2} in the flight direction and at \&pm;40 mrad (2.3\&deg;) angles relative to it in both, horizontal and vertical directions. The approaches started at up to 25 km distance to the plume and SO\textsubscript{2} was measured at all times well above the detection limit. In combination with radiative transfer studies, this study indicates that an extended volcanic cloud with a concentration of 10\textsuperscript{12} molecules cm\textsuperscript{\&minus;3} at typical flight levels of 10 km can be detected unambiguously at distances of up to 80 km away. This range provides enough time (approx. 5 min) for pilots to take action to avoid entering a volcanic cloud in the flight path, suggesting that this technique can be used as an effective aid to prevent dangerous aircraft encounters with potentially ash rich volcanic clouds.{$<$}/p{$>$}},
  langid = {english},
  keywords = {nosource}
}

