@article{cookeDetectionGrimsvotn20112014,
  title = {Detection of the {{Gr\'imsv\"otn}} 2011 Volcanic Eruption Plumes Using Infrared Satellite Measurements},
  author = {Cooke, Michael C. and Francis, Peter N. and Millington, Sarah and Saunders, Roger and Witham, Claire},
  year = 2014,
  journal = {Atmospheric Science Letters},
  volume = {15},
  number = {4},
  pages = {321--327},
  issn = {1530-261X},
  doi = {10.1002/asl2.506},
  urldate = {2021-01-06},
  abstract = {Infrared satellite measurements were used to track the volcanic plume from Gr\'imsv\"otn, Iceland in 2011. Following the explosive eruption, the plume was sheared by the atmosphere into two distinct volcanic clouds, one was ash-rich and the other was mainly composed of sulphur dioxide (SO2) gas. Satellite retrievals of the volcanic ash were found to be consistent with an andesitic/basaltic composition, providing a framework for composition evaluation immediately following an eruption. SO2 was detectable for several weeks following the eruption highlighting the importance of monitoring volcanic clouds for a prolonged period to manage the associated risk of air traffic.},
  langid = {english},
  keywords = {IASI,Meteosat,nosource,satellite,SEVIRI,sulphur dioxide,volcanic ash}
}

