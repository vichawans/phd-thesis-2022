  shorttitle = {The {{Joint UK Land Environment Simulator}} ({{JULES}}), Model Description -- {{Part}} 1},
  author = {Best, M. J. and Pryor, M. and Clark, D. B. and Rooney, G. G. and Essery, R. L. H. and M{\'e}nard, C. B. and Edwards, J. M. and Hendry, M. A. and Porson, A. and Gedney, N. and Mercado, L. M. and Sitch, S. and Blyth, E. and Boucher, O. and Cox, P. M. and Grimmond, C. S. B. and Harding, R. J.},
