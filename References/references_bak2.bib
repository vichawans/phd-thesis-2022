  langid = {english},
  keywords = {Atmospheric chemistry,Climate and Earth system modelling,VS_paper1},
  file = {C:\Users\print\Zotero\storage\DI589HFW\Skeie et al. - 2020 - Historical total ozone radiative forcing derived f.pdf}
}

@article{slemrHydroperoxidesMarineTroposphere1994,
