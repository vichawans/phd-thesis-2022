  issn = {0960-1686},
  doi = {10.1016/0960-1686(91)90159-5},
  urldate = {2024-12-12},
  abstract = {Most of the so-called `CO2 effect' is, in fact, an `H2O effect' brought into play by the climate modeler's assumption that planetary average temperature dictates water-vapor concentration (following Clapeyron-Clausius). That assumption ignores the removal process, which cloud physicists know to be influenced by the aerosol, since the latter primarily controls cloud droplet number and size. Droplet number and size are also influential for shortwave (solar) energy. The reflectance of many thin to moderately thick clouds changes when nuclei concentrations change and make shortwave albedo susceptible to aerosol influence.},
  keywords = {nosource},
