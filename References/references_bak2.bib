  number = {1},
  pages = {1--8},
  publisher = {Nature Publishing Group},
  issn = {2397-3722},
  doi = {10.1038/s41612-020-00159-2},
  urldate = {2024-04-29},
  abstract = {Anthropogenic aerosol (AA) forcing has been shown as a critical driver of climate change over Asia since the mid-20th century. Here we show that almost all Coupled Model Intercomparison Project Phase 6 (CMIP6) models fail to capture the observed dipole pattern of aerosol optical depth (AOD) trends over Asia during 2006--2014, last decade of CMIP6 historical simulation, due to an opposite trend over eastern China compared with observations. The incorrect AOD trend over China is attributed to problematic AA emissions adopted by CMIP6. There are obvious differences in simulated regional aerosol radiative forcing and temperature responses over Asia when using two different emissions inventories (one adopted by CMIP6; the other from Peking university, a more trustworthy inventory) to driving a global aerosol-climate model separately. We further show that some widely adopted CMIP6 pathways (after 2015) also significantly underestimate the more recent decline in AA emissions over China. These flaws may bring about errors to the CMIP6-based regional climate attribution over Asia for the last two decades and projection for the next few decades, previously anticipated to inform a wide range of impact analysis.},
  copyright = {2021 The Author(s)},
  langid = {english},
  keywords = {Climate and Earth system modelling,Projection and prediction},
  file = {C:\Users\print\Zotero\storage\7ZXGI8TW\Wang et al. - 2021 - Incorrect Asian aerosols affecting the attribution.pdf}
}

@article{wangStratosphericChlorineProcessing2023,
  title = {Stratospheric Chlorine Processing after the 2020 {{Australian}} Wildfires Derived from Satellite Data},
  author = {Wang, Peidong and Solomon, Susan and Stone, Kane},
  year = 2023,
  month = mar,
  journal = {Proceedings of the National Academy of Sciences},
  volume = {120},
  number = {11},
  pages = {e2213910120},
  publisher = {Proceedings of the National Academy of Sciences},
  doi = {10.1073/pnas.2213910120},
  urldate = {2025-04-18},
  abstract = {The 2019 to 2020 Australian summer wildfires injected an amount of organic gases and particles into the stratosphere unprecedented in the satellite record since 2002, causing large unexpected changes in HCl and ClONO2. These fires provided a novel opportunity to evaluate heterogeneous reactions on organic aerosols in the context of stratospheric chlorine and ozone depletion chemistry. It has long been known that heterogeneous chlorine (Cl) activation occurs on the polar stratospheric clouds (PSCs; liquid and solid particles containing water, sulfuric acid, and in some cases nitric acid) that are found in the stratosphere, but these are only effective for ozone depletion chemistry at temperatures below about 195 K (i.e., largely in the polar regions during winter). Here, we develop an approach to quantitatively assess atmospheric evidence for these reactions using satellite data for both the polar (65 to 90{$^\circ$}S) and the midlatitude (40 to 55{$^\circ$}S) regions. We show that heterogeneous reactions apparently even happened at temperatures at 220 K during austral autumn on the organic aerosols present in 2020 in both regions, in contrast to earlier years. Further, increased variability in HCl was also found after the wildfires, suggesting diverse chemical properties among the 2020 aerosols. We also confirm the expectation based upon laboratory studies that heterogeneous Cl activation has a strong dependence upon water vapor partial pressure and hence atmospheric altitude, becoming much faster close to the tropopause. Our analysis improves the understanding of heterogeneous reactions that are important for stratospheric ozone chemistry under both background and wildfire conditions.},
  file = {C:\Users\print\Zotero\storage\4SSREZQP\Wang et al. - 2023 - Stratospheric chlorine processing after the 2020 Australian wildfires derived from satellite data.pdf}
}

