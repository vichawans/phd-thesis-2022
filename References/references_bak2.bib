@article{giannakopoulosValidationIntercomparisonWet1999,
  title = {Validation and Intercomparison of Wet and Dry Deposition Schemes Using {{210Pb}} in a Global Three-Dimensional off-Line Chemical Transport Model},
  author = {Giannakopoulos, C. and Chipperfield, M. P. and Law, K. S. and Pyle, J. A.},
