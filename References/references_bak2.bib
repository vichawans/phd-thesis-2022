@article{riegerTransClimV1Chemistryclimate2021,
  title = {{{TransClim}} (v1.0): {{A}} Chemistry-Climate Response Model for Assessing the Effect of Mitigation Strategies for Road Traffic on Ozone},
  shorttitle = {{{TransClim}} (v1.0)},
  author = {Rieger, Vanessa Simone and Grewe, Volker},
  year = 2021,
  month = may,
  journal = {Geoscientific Model Development Discussions},
  pages = {1--30},
  publisher = {Copernicus GmbH},
  issn = {1991-959X},
  doi = {10.5194/gmd-2021-127},
  urldate = {2021-05-07},
  abstract = {{$<$}p{$><$}strong class="journal-contentHeaderColor"{$>$}Abstract.{$<$}/strong{$>$} Road traffic emits not only carbon dioxide (CO\textsubscript{2}), but also other pollutants such as nitrogen oxides (NO\textsubscript{x}), volatile organic compounds (VOC) and carbon monoxide (CO). These chemical species influence the atmospheric chemistry and produce ozone (O\textsubscript{3}) in the troposphere. Ozone acts as a greenhouse gas and thus contributes to anthropogenic global warming. Technological trends and political decisions can help to reduce the O\textsubscript{3} effect of road traffic emissions on climate. In order to assess the O\textsubscript{3} response of such mitigation options on climate, we developed a chemistry-climate response model called TransClim (Modelling the effect of surface {$<$}em{$>$}Trans{$<$}/em{$>$}portation on {$<$}em{$>$}Clim{$<$}/em{$>$}ate). It considers road traffic emissions of NO\textsubscript{x}, VOC and CO and determines the O\textsubscript{3} change and its corresponding stratospheric-adjusted radiative forcing. Using a tagging method, TransClim is further able to quantify the contribution of road traffic emissions to the O\textsubscript{3} concentration. The response model bases on lookup-tables which are generated by a set of emission variation simulations performed with the global chemistry climate model EMAC (ECHAM5 v5.3.02, MESSy v2.53.0). Evaluating TransClim against independent EMAC simulations reveals very low deviations of all considered species (0.01\&ndash;7\&thinsp;\%). Hence, TransClim is able to reproduce the results of an EMAC simulation very well. Moreover, TransClim is about 6000 times faster in computing the climate effect of an emission scenario than the complex chemistry-climate model. This makes TransClim a suitable tool to efficiently assess the climate effect of a broad range of mitigation options for road traffic or to analyse uncertainty ranges by employing Monte-Carlo simulations.{$<$}/p{$>$}},
  langid = {english},
  keywords = {nosource}
}

