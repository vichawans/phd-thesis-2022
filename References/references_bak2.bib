@article{paulotContrastingSeasonalResponses2017,
  title = {Contrasting Seasonal Responses of Sulfate Aerosols to Declining {{SO2}} Emissions in the {{Eastern U}}.{{S}}.: {{Implications}} for the Efficacy of {{SO2}} Emission Controls},
  shorttitle = {Contrasting Seasonal Responses of Sulfate Aerosols to Declining {{SO2}} Emissions in the {{Eastern U}}.{{S}}.},
  author = {Paulot, F. and Fan, S. and Horowitz, L. W.},
