@article{itterlyQuantifyingTropopauseOvershootingVolume2025,
  title = {Quantifying {{Tropopause-Overshooting Volume From Satellite}} and {{Radar Observations During}} the {{DCOTSS}} 2021 and 2022 {{Campaigns}}},
  author = {Itterly, Kyle F. and Bedka, Kristopher M. and Homeyer, Cameron R. and Khlopenkov, Konstantin},
  year = 2025,
  journal = {Journal of Geophysical Research: Atmospheres},
  volume = {130},
  number = {7},
  pages = {e2024JD042418},
  issn = {2169-8996},
  doi = {10.1029/2024JD042418},
  urldate = {2025-05-05},
  abstract = {This study quantifies the air volume injected into the stratosphere by overshooting convection detected by GOES-16/17 geostationary infrared imagery and NOAA NEXRAD precipitation echo top during the 2021 and 2022 Dynamics and Chemistry of the Summer Stratosphere (DCOTSS) missions. This analysis addresses a key DCOTSS science question, namely ``How much tropospheric air and water is irreversibly injected into the stratosphere by convection?'' A novel method for defining individual storms or a cluster of adjacent storms as objects and tracking them throughout their lifetime facilitates the analysis. Overshooting convection injected 3.92 \texttimes{} 106 -- 5.36 \texttimes{} 106 km3 of air into the stratosphere in 2021 and 9.59 \texttimes{} 106 -- 1.06 \texttimes{} 107 km3 in 2022 over the North American study domain with GOES being higher than GridRad during both years. GOES overshooting detections were more uncertain due to difficulty differentiating updrafts from adjacent broad areas of cold outflow. Overshooting volume from the top 10 storm objects each year contributed 37\%--52\% of the total domain-wide volume. Total object-lifetime volume from these events ranged from {$\sim$}1.3 \texttimes{} 105 to 7.9 \texttimes{} 105 km3 for GOES and {$\sim$}8.7 \texttimes{} 104 to 8.0 \texttimes{} 105 km3 for GridRad. Overshooting seldom exceeded 5\% of the total anvil area, and most often occupied {$<$}1\%, demonstrating that very small regions within convection are responsible for impacting stratosphere composition. Despite differences in overshooting characteristics, airmasses initiated from GOES and NEXRAD overshooting and advected forward in time by reanalysis model winds had similar spatial and vertical distributions, indicating that geostationary satellite data could be used to study the long-range transport of overshooting airmasses.},
  copyright = {\copyright{} 2025. American Geophysical Union. All Rights Reserved.},
  langid = {english},
  keywords = {dynamics and chemistry of the summer stratosphere,GOES advanced baseline imager,GridRad,nosource,sensor inter-comparison,stratospheric water vapor,tropopause-overshooting volume},
  file = {C:\Users\print\Zotero\storage\YFGTFA8B\2024JD042418.html}
}

