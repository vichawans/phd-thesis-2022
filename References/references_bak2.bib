@article{duttaCharacterizingGlobalTropospheric2026,
  title = {Characterizing the {{Global Tropospheric Budget}} of {{Oxidized Nitrogen}} ({{NO}}{\textsubscript{y}})},
  author = {Dutta, Ishir and Heald, Colette L. and Bourgeois, Ilann and Crounse, John D. and Hintsa, Eric J. and Moore, Fred L. and Peischl, Jeff},
  year = 2026,
  month = feb,
  journal = {EGUsphere},
  pages = {1--28},
  publisher = {Copernicus GmbH},
  doi = {10.5194/egusphere-2026-875},
  urldate = {2026-02-26},
  abstract = {{$<$}p{$><$}strong class="journal-contentHeaderColor"{$>$}Abstract.{$<$}/strong{$>$} Nitrogen oxides (NO\textsubscript{x} = NO + NO\textsubscript{2}) in the troposphere form an array of secondary pollutants that are detrimental to air quality, ecosystems, and climate. The family of reactive oxidized nitrogen (NO\textsubscript{y}) in the atmosphere consists of NO\textsubscript{x} and its reservoir species (e.g. HNO\textsubscript{3}, PAN). Our understanding of the processes underlying the transformation of NO\textsubscript{y} has advanced considerably over recent decades, however, the relative importance of NO\textsubscript{y} partitioning and loss pathways remain uncertain. In this study, we use the GEOS-Chem global chemical transport model and observations from the ATom flight campaign to assess the simulated global budget of tropospheric NO\textsubscript{y}, and the production and loss fluxes between key NO\textsubscript{y} species. Our simulation indicates that the mean global chemical lifetime of NO\textsubscript{x} is \textasciitilde 21 hours and the mean global deposition lifetime of NO\textsubscript{y} is 5.5 days. The global mean NO\textsubscript{x}:NO\textsubscript{y} ratio at the surface is 0.23 (over continents it is 0.34) and at 500 hPa is 0.10. In addition to the four most prevalent gas-phase species (NO, NO\textsubscript{2}, HNO\textsubscript{3}, PAN) that have been central to previous descriptions of tropospheric NO\textsubscript{y} chemistry, we find that other species play key roles in driving overall chemical cycling.{$<$}strong{$>$} {$<$}/strong{$>$}The model representation of organic nitrate chemistry is highly simplified and likely overestimates the importance of hydrolysis as a sink while underestimating deposition. Finally, the photolytic loss of particulate nitrate (pNO\textsubscript{3}\textsuperscript{-}) to form NO\textsubscript{2} and HONO, as represented in our simulations, is comparable to its depositional loss, indicating the importance of further constraining this photolysis sink.{$<$}/p{$>$}},
  langid = {english},
  annotation = {duttaCharacterizingGlobalTropospheric2026},
  file = {C:\Users\print\Zotero\storage\3AMPKC2A\Dutta et al. - 2026 - Characterizing the Global Tropospheric Budget of Oxidized Nitrogen (NOy).pdf}
}

